{
  "name": "mockup-compiler-js",
  "version": "1.2.1",
  "description": "Tool to convert Excel unit test data to text and archive it",
  "type": "module",
  "bin": {
    "mockup-compiler": "./src/index.ts",
    "mockup-validator": "./src/validator.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "testrun": "node src/index.ts -c test-sample/.mock-config.json",
    "testrun:t": "node src/index.ts -c test-sample/.mock-config.json --bundle-format text -z ../_dest/build.txt",
    "testrun:tz": "node src/index.ts -c test-sample/.mock-config.json --bundle-format text+zip -z ../_dest/build-tz.zip",
    "lint": "eslint",
    "build:bin": "bash bin/build-sea.sh",
    "build:bundle": "esbuild --format=cjs --platform=node --bundle --outfile=_build/bundle.js src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sbcgua/mockup-compiler-js.git"
  },
  "private": false,
  "author": "Alexander Tsybulsky",
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "chalk": "^5.5.0",
    "commander": "^14.0.0",
    "lodash-es": "^4.17.23",
    "memfs": "^4.24.0",
    "picomatch": "^4.0.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/lodash-es": "^4.17.12",
    "deep-freeze": "0.0.1",
    "esbuild": "^0.25.5",
    "eslint": "^9.29.0",
    "globals": "^16.2.0",
    "@types/node": "^24.0.7",
    "@types/picomatch": "^4.0.2",
    "postject": "^1.0.0-alpha.6",
    "resedit-cli": "^2.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
