{
  "name": "mockup-compiler-js",
  "version": "1.3.0-beta",
  "description": "Tool to convert Excel unit test data to text and archive it",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "bin": {
    "mockup-compiler": "./src/index.ts",
    "mockup-validator": "./src/validator.ts"
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun --watch test",
    "typecheck": "tsc --noEmit",
    "verify": "bun run lint && bun run typecheck && bun test && bun run build:bundle",
    "smoke:runtime": "bun run testrun && bun run testrun:tm",
    "testrun": "bun src/index.ts -c test-sample/.mock-config.json",
    "testrun:clean": "rm -rf _dest/* _dest/.meta",
    "testrun:t": "bun src/index.ts -c test-sample/.mock-config.json --bundle-format text -z ../_dest/build.txt",
    "testrun:tm": "bun src/index.ts -c test-sample/.mock-config.json --bundle-format text --in-mem -d \"\" -z ../_dest/build.txt",
    "testrun:tz": "bun src/index.ts -c test-sample/.mock-config.json --bundle-format text+zip -z ../_dest/build-tz.zip",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "build:bin": "bun scripts/build-bin.ts",
    "build:bundle": "bun scripts/build-bundle.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sbcgua/mockup-compiler-js.git"
  },
  "private": false,
  "author": "Alexander Tsybulsky",
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "chalk": "^5.5.0",
    "commander": "^14.0.0",
    "lodash-es": "^4.17.23",
    "memfs": "^4.24.0",
    "picomatch": "^4.0.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/archiver": "^6.0.3",
    "@types/bun": "^1.3.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.0.7",
    "@types/picomatch": "^4.0.2",
    "deep-freeze": "0.0.1",
    "eslint": "^9.29.0",
    "globals": "^17.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2"
  }
}
